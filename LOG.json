        {
          "query": "from(bucket: \"zeek\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => r[\"_measurement\"] == \"normal_traffic\" and r[\"top_ip\"] !~ /:/)\r\n  |> pivot(rowKey:[\"_time\"], columnKey: [\"_field\"], valueColumn: \"_value\")\r\n  |> sort(columns: [\"_time\"], desc: true)\r\n  |> map(fn: (r) => ({\r\n      \"Čas\": r._time,\r\n      \"Režim\": r.mode,\r\n      \"Spojení\": r.connections,\r\n      \"Chybovost spojení\": if exists r.fail_ratio then string(v: int(v: r.fail_ratio * 100.0)) + \" %\" else \"0 %\",\r\n      \"Unikátní porty\": r.unique_ports,\r\n      \"Unikátní IP\": r.unique_ips,\r\n      \"Nejaktivnější zařízení\": r.top_ip + \" (\" + r.device + \" - \" + r.top_mac + \")\"\r\n  }))",
          "refId": "A"
        }
      ],
      "title": "Provoz v normě",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "includeByName": {},
