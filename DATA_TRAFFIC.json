      "targets": [
        {
          "query": "from(bucket: \"zeek\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => \r\n      r.path =~ /dns/ and \r\n      r[\"id.orig_h\"] =~ /^192\\.168\\.69\\./ and \r\n      exists r.query\r\n  )\r\n  |> group(columns: [\"query\", \"id.orig_h\"])\r\n  |> reduce(\r\n      fn: (r, accumulator) => ({\r\n        Query_count: accumulator.Query_count + 1,\r\n        Last_query: if r._time > accumulator.Last_query then r._time else accumulator.Last_query\r\n      }),\r\n      identity: {\r\n        Query_count: 0,\r\n        Last_query: 1970-01-01T00:00:00Z\r\n      }\r\n    )\r\n  |> group()\r\n  |> sort(columns: [\"Query_count\"], desc: true)\r\n  |> map(fn: (r) => ({\r\n      \"Čas posledního dotazu\": r.Last_query,\r\n      \"Doména\": r.query,\r\n      \"Počet dotazů\": r.Query_count,\r\n      \"Zdrojová IP\": r[\"id.orig_h\"]\r\n  }))",
          "refId": "A"
        }
