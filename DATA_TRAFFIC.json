      "targets": [
        {
          "query": "from(bucket: \"zeek\")\r\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |> filter(fn: (r) => \r\n      r[\"_measurement\"] == \"tail\" and \r\n      r[\"path\"] == \"/opt/zeek/spool/zeek/conn.log\" and \r\n      r[\"id.orig_h\"] =~ /^192\\.168\\.69\\./ and \r\n      (r[\"_field\"] == \"resp_bytes\" or r[\"_field\"] == \"orig_bytes\")\r\n  )\r\n  |> map(fn: (r) => ({ \r\n      r with \r\n      orig_l2_addr: if exists r.orig_l2_addr then r.orig_l2_addr else \"unknown\"\r\n  }))\r\n  |> pivot(\r\n      rowKey:[\"_time\", \"id.orig_h\", \"orig_l2_addr\"], \r\n      columnKey: [\"_field\"], \r\n      valueColumn: \"_value\"\r\n  )\r\n  |> map(fn: (r) => {\r\n      orig = if exists r.orig_bytes then float(v: r.orig_bytes) else 0.0\r\n      resp = if exists r.resp_bytes then float(v: r.resp_bytes) else 0.0\r\n      return {\r\n          _time: r._time,\r\n          _field: r[\"id.orig_h\"] + \" (\" + r.orig_l2_addr + \")\",\r\n          _value: (orig + resp) / 1048576.0 \r\n      }\r\n  })\r\n  |> group(columns: [\"_field\"])\r\n  |> aggregateWindow(every: 1m, fn: sum, createEmpty: false)",
          "refId": "A"
        }
      ],
      "title": "Celkový provoz",
      "type": "timeseries"
